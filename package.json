{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --ext .js,.ts,.vue,.jsx,.tsx",
    "lint:fix": "eslint . --ext .js,.ts,.vue,.jsx,.tsx --fix",
    "stylelint": "stylelint \"**/*.{css,scss,less}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss,less}\" --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/content": "^3.14.0",
    "@nuxt/ui": "^4.7.1",
    "@tresjs/cientos": "^4.3.1",
    "@tresjs/nuxt": "^4.0.0",
    "better-sqlite3": "^12.10.0",
    "cosmo-lib": "^1.0.6",
    "express": "^5.2.1",
    "motion-v": "^2.2.1",
    "three": "^0.180.0",
    "vue": "latest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@iconify-json/ph": "^1.2.2",
    "@nuxt/image": "1.11.0",
    "@types/express": "^5.0.6",
    "@vueuse/core": "^13.9.0",
    "@vueuse/nuxt": "^13.9.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.6",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.13"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "pnpm -s eslint --fix"
    ],
    "*.{css,scss,less}": "pnpm -s stylelint --fix"
  }
}
